# انسخ هذا الملف إلى ".env" ثم عدّل القيم بحسب بيئتك المحلية

# رابط الاتصال بقاعدة بيانات PostgreSQL
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/agrivision

# مفتاح سري لتوقيع JWT — يجب تغييره لقيمة عشوائية طويلة في الإنتاج
SECRET_KEY=CHANGE-THIS-SECRET-KEY-IN-PRODUCTION
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# خدمة الطقس الخارجية (Open-Meteo لا تتطلب مفتاح API)
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1/forecast

# نطاقات مسموح لها بالاتصال بالـ API (CORS) — مفصولة بفواصل عند الحاجة لتقييدها
CORS_ORIGINS=["*"]
